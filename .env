# Auto-Rust Environment Configuration
# Updated: April 2026

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider: "ollama" or "openrouter"
LLM_PROVIDER=ollama

# OpenRouter Settings (get key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Ollama Settings (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# =============================================================================
# Twitter Activity Settings
# =============================================================================
TWITTER_LLM_ENABLED=false
TWITTER_LLM_PROVIDER=ollama
TWITTER_LLM_MODEL=llama3.2:3b
TWITTER_LLM_REPLY_PROBABILITY=0.05
TWITTER_LLM_QUOTE_PROBABILITY=0.15

# Engagement Limits (Conservative, safe for testing)
TWITTER_MAX_LIKES=5
TWITTER_MAX_RETWEETS=3
TWITTER_MAX_FOLLOWS=2
TWITTER_MAX_REPLIES=3
TWITTER_MAX_THREAD_DIVES=3
TWITTER_MAX_TOTAL_ACTIONS=10

# =============================================================================
# Browser Configuration
# =============================================================================
ROXYBROWSER_API_URL=http://127.0.0.1:50000/
ROXYBROWSER_API_KEY=c6ae203adfe0327a63ccc9174c178dec

CURSOR_OVERLAY_MS=50

# Orchestrator Settings
MAX_GLOBAL_CONCURRENCY=20
TASK_TIMEOUT_MS=600000
MAX_RETRIES=2