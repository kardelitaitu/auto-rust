# =============================================================================
# Auto-Rust Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's already in .gitignore)

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider: "ollama" (local, free) or "openrouter" (cloud, paid)
LLM_PROVIDER=ollama

# --- Ollama (Local, Free) ---
# Install: https://ollama.ai/download
# Run: ollama pull llama3.2:3b
# API runs on http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# Alternative models:
# OLLAMA_MODEL=llama3.2:latest
# OLLAMA_MODEL=mistral:latest
# OLLAMA_MODEL=llama3.1:8b

# --- OpenRouter (Cloud, Paid) ---
# Get API key: https://openrouter.ai/keys
# Add credits (min $5 recommended)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku
# Alternative models:
# OPENROUTER_MODEL=anthropic/claude-3-sonnet
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# =============================================================================
# Twitter Activity Persona Probabilities
# =============================================================================
# Base engagement probabilities (0.0 - 1.0)
# These can be overridden per-task via payload weights
TWITTER_LIKE_PROBABILITY=0.30         # 30% chance to like a tweet
TWITTER_RETWEET_PROBABILITY=0.10     # 10% chance to retweet
TWITTER_QUOTE_PROBABILITY=0.05       # 5% chance to quote tweet
TWITTER_FOLLOW_PROBABILITY=0.05      # 5% chance to follow author
TWITTER_REPLY_PROBABILITY=0.02       # 2% chance to reply
TWITTER_THREAD_DIVE_PROBABILITY=0.20 # 20% chance to dive into thread

# =============================================================================
# Twitter Activity V2 (LLM-Powered Features)
# =============================================================================
# Enable LLM-powered replies and quote tweets
TWITTER_LLM_ENABLED=false
TWITTER_LLM_PROVIDER=ollama
TWITTER_LLM_MODEL=llama3.2:3b
# TWITTER_LLM_MODEL=anthropic/claude-3-haiku  # If using OpenRouter

# LLM-specific reply probability (overrides base TWITTER_REPLY_PROBABILITY when LLM enabled)
TWITTER_LLM_REPLY_PROBABILITY=0.05     # 5% chance to reply to eligible tweets

# =============================================================================
# Engagement Limits (Rate Limit Protection)
# =============================================================================
TWITTER_MAX_LIKES=5
TWITTER_MAX_RETWEETS=3
TWITTER_MAX_FOLLOWS=2
TWITTER_MAX_REPLIES=3
TWITTER_MAX_THREAD_DIVES=3
TWITTER_MAX_QUOTE_TWEETS=2
TWITTER_MAX_TOTAL_ACTIONS=10

# =============================================================================
# Browser Configuration
# =============================================================================
# RoxyBrowser (cloud browsers)
ROXYBROWSER_API_URL=http://127.0.0.1:50000/
ROXYBROWSER_API_KEY=

# Browser settings
BROWSER_USER_AGENT=
BROWSER_EXTRA_HTTP_HEADERS=

# Cursor overlay (visual cursor for debugging/demos)
# 0 = disabled, 50 = smooth, 100 = visible but choppy
CURSOR_OVERLAY_MS=50
MOUSE_OVERLAY_SIZE_PX=12

# Native click calibration profile
# Supported values: windows, mac, linux
native_click_calibration=windows

# Native interaction timing
# Increase if native clicks/moves race page rendering or load slowly
NATIVE_INTERACTION_STABILITY_WAIT_MS=5000
NATIVE_INTERACTION_RESOLVE_TIMEOUT_MS=2000
# Optional minimum settle pause applied to native click/move actions
NATIVE_INTERACTION_SETTLE_MS=0

# =============================================================================
# Orchestrator Configuration
# =============================================================================
# Task execution
MAX_GLOBAL_CONCURRENCY=20          # Max parallel tasks (1-100)
TASK_TIMEOUT_MS=600000             # 10 minutes per task
GROUP_TIMEOUT_MS=600000            # 10 minutes per task group
MAX_RETRIES=2                      # Retry failed tasks
WORKER_WAIT_TIMEOUT_MS=10000       # 10s to acquire worker

# Stagger delay between task starts (prevents network spikes)
TASK_STAGGER_DELAY_MS=2000

# =============================================================================
# Logging
# =============================================================================
# Levels: error, warn, info, debug, trace
# RUST_LOG=info
# RUST_LOG=debug,orchestrator=trace

# =============================================================================
# Testing / Development
# =============================================================================
# PAGEVIEW_OVERLAY_TEST_MODE=true
# CURSOR_SPEED_BOOST_FACTOR=2



# Auto-Rust Environment Configuration
# Updated: April 2026

RUST_LOG=debug
# .env based mouse calibration choose either mac / windows / linux
native_click_calibration=mac

