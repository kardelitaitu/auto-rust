# =============================================================================
# Auto-Rust Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# =============================================================================
# LLM Configuration (Choose ONE provider)
# =============================================================================

# --- OPTION 1: Ollama (FREE, Recommended) ---
# 1. Install: https://ollama.ai/download
# 2. Pull model: ollama pull llama3.2
# 3. Ollama runs automatically on http://localhost:11434

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_MODEL=mistral:latest           # Alternative
# OLLAMA_MODEL=llama3.1:8b              # Better quality, slower

# --- OPTION 2: OpenRouter (Paid, Premium Models) ---
# 1. Get API key: https://openrouter.ai/keys
# 2. Add credits (min $5)
# 3. Set your API key below

OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx  # REPLACE WITH YOUR KEY
OPENROUTER_MODEL=anthropic/claude-3-haiku
# OPENROUTER_MODEL=openai/gpt-3.5-turbo    # Alternative
# OPENROUTER_MODEL=meta-llama/llama-3-8b  # Cheaper option

# =============================================================================
# Twitter Activity Configuration
# =============================================================================

# Enable/disable features
TWITTER_LLM_ENABLED=true
TWITTER_SMART_DECISION_ENABLED=true

# Engagement probabilities (0.0 - 1.0)
TWITTER_LLM_REPLY_PROBABILITY=0.05        # 5% of eligible tweets
TWITTER_LLM_QUOTE_PROBABILITY=0.15        # 15% of retweets become quotes

# Engagement limits (per session)
TWITTER_MAX_LIKES=5
TWITTER_MAX_RETWEETS=3
TWITTER_MAX_FOLLOWS=2
TWITTER_MAX_REPLIES=3
TWITTER_MAX_QUOTE_TWEETS=2
TWITTER_MAX_TOTAL_ACTIONS=10

# =============================================================================
# Browser Configuration
# =============================================================================

# RoxyBrowser (if using)
ROXYBROWSER_API_URL=http://127.0.0.1:50000/
ROXYBROWSER_API_KEY=c6ae203adfe0327a63ccc9174c178dec

# Browser settings
BROWSER_USER_AGENT=
BROWSER_EXTRA_HTTP_HEADERS=

# =============================================================================
# Orchestrator Configuration
# =============================================================================

MAX_GLOBAL_CONCURRENCY=20
TASK_TIMEOUT_MS=600000
GROUP_TIMEOUT_MS=600000
MAX_RETRIES=2

# =============================================================================
# API Keys (Optional - for other features)
# =============================================================================

# OPENAI_API_KEY=           # If using OpenAI directly
# ANTHROPIC_API_KEY=        # If using Anthropic directly

# =============================================================================
# Testing & Debug
# =============================================================================

# Enable verbose logging
# RUST_LOG=debug

# Test mode (dry run, no actual actions)
# TWITTER_TEST_MODE=true
