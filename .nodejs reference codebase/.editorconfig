# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript, JSON, YAML, Markdown
[*.{js,json,yml,yaml,md}]
indent_style = space
indent_size = 2

# Markdown - don't trim trailing whitespace (preserve formatting)
[*.md]
trim_trailing_whitespace = false

# PowerShell
[*.ps1]
indent_style = space
indent_size = 4

# React/JSX
[*.{jsx,tsx}]
indent_style = space
indent_size = 2

# Package files
[package.json]
indent_style = space
indent_size = 2