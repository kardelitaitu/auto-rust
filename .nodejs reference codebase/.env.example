# =============================================================================
# Auto-AI Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Command: copy .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Choose ONE option: Local LLM (Ollama) OR Cloud LLM (OpenRouter)
# Local LLM is free but requires Ollama running locally
# Cloud LLM requires API key but provides better reasoning

# --- Local LLM (Ollama) ---
# Set to your Ollama endpoint (default: http://localhost:11434)
LOCAL_LLM_ENDPOINT=http://localhost:11434/api/generate

# Model name for Ollama (e.g., llama3, gemma3:4b, mistral)
LOCAL_LLM_MODEL=gemma3:4b

# --- Cloud LLM (OpenRouter) ---
# Get your API key from https://openrouter.ai/keys
# Leave empty to use only local LLM
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Default model for OpenRouter (e.g., anthropic/claude-3.5-sonnet, openai/gpt-4)
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# -----------------------------------------------------------------------------
# System Settings
# -----------------------------------------------------------------------------

# Environment: development, production, test
NODE_ENV=development

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Humanization Settings (Optional)
# -----------------------------------------------------------------------------
# Enable/disable human-like behavior simulation
# These override config/settings.json when set

# HUMANIZE_MOUSE=true
# HUMANIZE_KEYBOARD=true
# HUMANIZE_SCROLL=true
# PERSONA=casual

# -----------------------------------------------------------------------------
# Browser Settings (Optional)
# -----------------------------------------------------------------------------
# Override browser discovery ports if needed

# IXBROWSER_PORT=53200
# MORELOGIN_PORT=6699
# DOLPHIN_PORT=5050
# BRAVE_PORT=9222

# -----------------------------------------------------------------------------
# Advanced Settings (Optional)
# -----------------------------------------------------------------------------

# Enable debug mode for detailed logging
# HUMAN_DEBUG=true

# Task timeout in milliseconds (default: 30000)
# TASK_TIMEOUT=30000

# Maximum concurrent browser sessions (default: 3)
# MAX_CONCURRENT_SESSIONS=3

# Proxy configuration (if required)
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Lines starting with # are comments
# - Empty values are ignored
# - Restart the application after changing environment variables
# - Never commit .env to version control (it's in .gitignore)
# - Use .env.example as a template for sharing configuration requirements
