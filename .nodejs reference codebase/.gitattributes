# Auto-AI Git Attributes
# https://git-scm.com/docs/gitattributes

# Line endings - normalize to LF on all platforms
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.mp4 binary
*.webm binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Build artifacts
node_modules/ -diff -merge
dist/ -diff -merge
build/ -diff -merge
coverage/ -diff -merge
logs/ -diff -merge
data/ -diff -merge

# Environment files (should not be tracked)
.env -diff -merge
.env.local -diff -merge

# IDE settings (optional per-user)
.vscode/settings.json merge=ours
.idea/ -diff -merge

# OS files
.DS_Store -diff
Thumbs.db -diff
desktop.ini -diff

# Lock files (keep tracked but don't merge automatically)
pnpm-lock.yaml text
package-lock.json text

# Documentation
*.md text
*.mdx text

# Source files
*.js text
*.ts text
*.jsx text
*.tsx text
*.json text
*.yaml text
*.yml text
*.toml text

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Config files
*.config.js text
*.config.ts text
tsconfig.json text
jsconfig.json text
.eslintrc* text
.prettierrc* text

# Test files
*.test.js text
*.spec.js text
*.test.ts text
*.spec.ts text

# HTML/CSS
*.html text
*.css text
*.scss text
*.less text

# Templates
*.ejs text
*.pug text
*.hbs text
