{
    "server": {
        "port": 3001,
        "host": "localhost"
    },
    "ui": {
        "defaultCompact": false,
        "defaultAlwaysOnTop": false,
        "themes": ["dark", "light"],
        "defaultTheme": "dark"
    },
    "connect": {
        "autoConnect": true,
        "remoteHost": "",
        "remotePort": 3001
    },
    "broadcast": {
        "intervalMs": 2000,
        "pingTimeout": 60000,
        "pingInterval": 25000
    },
    "client": {
        "reconnectionAttempts": 10,
        "reconnectionDelay": 2000
    },
    "history": {
        "maxItems": 9999,
        "saveDebounceMs": 5000
    },
    "devServer": {
        "port": 5173
    },
    "security": {
        "cors": {
            "enabled": true,
            "origins": ["http://localhost:5173", "http://localhost:3001"]
        },
        "rateLimit": {
            "enabled": true,
            "windowMs": 60000,
            "maxRequests": 100
        },
        "sessionTTL": 300000,
        "auth": {
            "enabled": false,
            "token": "",
            "protectedEvents": ["clear-history", "send-notification", "push_metrics", "task-update"]
        }
    }
}
