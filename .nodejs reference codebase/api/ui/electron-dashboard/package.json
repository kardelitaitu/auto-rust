{
    "name": "auto-ai-dashboard",
    "version": "1.0.0",
    "description": "Monitoring dashboard for Auto-AI browser automation",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "start": "electron .",
        "dev": "electron .",
        "dev:ui": "cd renderer && npm run dev",
        "build:renderer": "cd renderer && npm run build",
        "dist": "npm run build:renderer && electron-builder --win portable",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "express": "^4.18.2",
        "socket.io": "^4.7.5"
    },
    "devDependencies": {
        "electron": "^35.7.5",
        "electron-builder": "^24.13.3",
        "vitest": "^1.6.1"
    },
    "build": {
        "appId": "com.autoai.dashboard",
        "productName": "Auto-AI Dashboard",
        "win": {
            "target": "portable",
            "icon": "icon.ico"
        },
        "files": [
            "**/*",
            "!renderer/node_modules",
            "!renderer/src",
            "renderer/dist/**/*"
        ],
        "directories": {
            "output": "dist-exe"
        },
        "asar": true
    },
    "engines": {
        "node": ">=16.0.0"
    }
}
